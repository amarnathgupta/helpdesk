// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS — Status/Role/Priority ke options
// ─────────────────────────────────────────

enum Role {
  ADMIN           // Hamaari company — full access
  INTERNAL_AGENT  // Hamare employees — sab agencies dekh sakte
  AGENCY_AGENT    // Partner ka agent — sirf apni agency
  CLIENT          // End user — sirf apne tickets
}

enum TicketStatus {
  OPEN
  PENDING
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageType {
  REPLY           // Customer/agent ka public reply
  INTERNAL_NOTE   // Sirf agents dekhenge — client ko nahi dikhega
}

// ─────────────────────────────────────────
// AGENCY — Multi-tenancy ki neenv yahi hai
// ─────────────────────────────────────────

model Agency {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique  // URL-friendly name e.g. "acme-corp"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  tickets     Ticket[]
  emailConfig EmailConfig?   // One agency = one email config

  @@map("agencies")
}

// ─────────────────────────────────────────
// EMAIL CONFIG — Per-agency email settings
// Inbound: kaunsa email address pe aayega
// Outbound: kaunse SMTP se reply jayega
// ─────────────────────────────────────────

model EmailConfig {
  id              String   @id @default(cuid())
  agencyId        String   @unique
  
  // Inbound — is address pe email aane se ticket banega
  inboundEmail    String   @unique  // e.g. support@acme.helpdesk.com

  // Outbound SMTP — is agency ke tickets ke replies
  // is SMTP se jayenge (client ko lagega agency ne bheja)
  smtpHost        String
  smtpPort        Int      @default(587)
  smtpUser        String
  smtpPass        String   // Baad mein encrypt karna
  smtpFromName    String   // e.g. "Acme Support"
  smtpFromEmail   String   // e.g. "support@acme.com"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("email_configs")
}

// ─────────────────────────────────────────
// USER — Sab roles ek hi table mein
// agencyId null = ADMIN ya INTERNAL_AGENT
// agencyId set = AGENCY_AGENT ya CLIENT
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CLIENT)
  isActive     Boolean  @default(true)

  // Agar AGENCY_AGENT ya CLIENT hai toh agency se belong karta hai
  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  assignedTickets  Ticket[]  @relation("AssignedAgent")
  createdTickets   Ticket[]  @relation("TicketCreator")
  messages         Message[]

  @@map("users")
}

// ─────────────────────────────────────────
// TICKET — Core entity
// ─────────────────────────────────────────

model Ticket {
  id           String         @id @default(cuid())
  subject      String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)

  // Ye ticket kis agency ka hai — MANDATORY
  agencyId     String
  agency       Agency         @relation(fields: [agencyId], references: [id])

  // Kisne banaya (client/email se auto-create)
  creatorId    String?
  creator      User?          @relation("TicketCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  // Kis agent ko assign kiya
  assignedToId String?
  assignedTo   User?          @relation("AssignedAgent", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Email se aaya tha? Thread track karne ke liye
  // Inbound email ka Message-ID header store karo
  // Taaki reply aane pe same ticket mein add ho
  emailMessageId  String?     @unique
  fromEmail       String?     // Kisne bheja (client email)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  closedAt     DateTime?

  messages     Message[]

  @@map("tickets")
}

// ─────────────────────────────────────────
// MESSAGE — Threaded conversation
// Ek ticket ke andar saari baatein yahan
// ─────────────────────────────────────────

model Message {
  id        String      @id @default(cuid())
  body      String      // HTML ya plain text
  type      MessageType @default(REPLY)

  ticketId  String
  ticket    Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Kisne likha — null matlab email se aaya (client logged in nahi tha)
  authorId  String?
  author    User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // Email se aaya tha toh track karo
  emailMessageId String?  // Email ka Message-ID (threading ke liye)
  fromEmail      String?  // Sender email

  createdAt DateTime    @default(now())

  @@map("messages")
}